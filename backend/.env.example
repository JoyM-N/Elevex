APP_NAME="Elevex API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3308
DB_DATABASE=elevex
DB_USERNAME=elevex_user
DB_PASSWORD=elevex_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Keep null when the Next.js proxy owns the browser origin (Vercel + Railway)
SESSION_DOMAIN=null
# Set true in production (HTTPS)
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Comma-separated browser origins that talk to the Next app (and thus the proxy)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# Comma-separated Next.js origins (CORS fallback for any direct API calls)
FRONTEND_URL=http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@elevex.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Railway production checklist (set in the Railway dashboard, not in git):
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://<your-railway-laravel-domain>
#   APP_KEY=<php artisan key:generate --show>
#   DB_* from Railway MySQL plugin (or MYSQL_URL / DATABASE_URL)
#   SESSION_SECURE_COOKIE=true
#   SANCTUM_STATEFUL_DOMAINS=<your-vercel-app>.vercel.app,app.yourdomain.com
#   FRONTEND_URL=https://<your-vercel-app>.vercel.app,https://app.yourdomain.com
#   RUN_SEED=true   # first deploy only, then remove
# Mount a volume at /app/storage for avatars / PDFs if keeping local disk.
# ---------------------------------------------------------------------------
